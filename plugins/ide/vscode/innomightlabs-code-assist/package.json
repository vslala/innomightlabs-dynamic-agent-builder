{
  "name": "innomightlabs-code-assist",
  "displayName": "innomightlabs-code-assist",
  "description": "An extension that helps you write code side-by-side like a pair programmer",
  "version": "0.0.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.113.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:innomightlabs-code-assist.explainCode",
    "onCommand:innomightlabs-code-assist.rewriteSelection",
    "onCommand:innomightlabs-code-assist.signIn",
    "onCommand:innomightlabs-code-assist.signOut",
    "onCommand:innomightlabs-code-assist.configureBackend",
    "onView:innomightlabs-code-assist.explainCodeView",
    "onView:innomightlabs-code-assist.conversationLogView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "innomightlabs-code-assist.explainCode",
        "title": "Explain Code",
        "category": "Innomightlabs"
      },
      {
        "command": "innomightlabs-code-assist.rewriteSelection",
        "title": "Rewrite Selected Code",
        "category": "Innomightlabs"
      },
      {
        "command": "innomightlabs-code-assist.signIn",
        "title": "Sign In with Google",
        "category": "Innomightlabs"
      },
      {
        "command": "innomightlabs-code-assist.signOut",
        "title": "Sign Out",
        "category": "Innomightlabs"
      },
      {
        "command": "innomightlabs-code-assist.configureBackend",
        "title": "Configure Backend",
        "category": "Innomightlabs"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "innomightlabs-code-assist.explainCode",
          "when": "editorHasSelection",
          "group": "navigation"
        },
        {
          "command": "innomightlabs-code-assist.rewriteSelection",
          "when": "editorHasSelection",
          "group": "navigation@1"
        }
      ],
      "commandPalette": [
        {
          "command": "innomightlabs-code-assist.rewriteSelection",
          "when": "editorHasSelection"
        }
      ]
    },
    "keybindings": [
      {
        "command": "innomightlabs-code-assist.rewriteSelection",
        "key": "alt+k r",
        "mac": "alt+k r",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "innomightlabs-code-assist-sidebar",
          "title": "Innomightlabs",
          "icon": "media/innomightlabs.svg"
        }
      ]
    },
    "views": {
      "innomightlabs-code-assist-sidebar": [
        {
          "type": "webview",
          "id": "innomightlabs-code-assist.explainCodeView",
          "name": "Code Explanation"
        },
        {
          "type": "webview",
          "id": "innomightlabs-code-assist.conversationLogView",
          "name": "Conversation Log"
        }
      ]
    },
    "configuration": {
      "title": "Innomightlabs Code Assist",
      "properties": {
        "innomightlabsCodeAssist.apiBaseUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "Base URL for the Innomightlabs backend API, for example `https://api.example.com`."
        },
        "innomightlabsCodeAssist.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "API key used when calling the Innomightlabs backend."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn run package",
    "compile": "yarn run check-types && yarn run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "yarn run check-types && yarn run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "yarn run compile-tests && yarn run compile && yarn run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.113.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
